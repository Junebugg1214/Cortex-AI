{
  "id": "cortexai-openclaw",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "storeDir": {
        "type": "string",
        "default": "~/.openclaw/cortex",
        "description": "Directory for the Cortex store used by the OpenClaw plugin. This should match the store used by the local cortexd API."
      },
      "apiBaseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:8766",
        "description": "Base URL for the local Cortex REST API. Keep this on loopback unless you have configured Cortex API authentication."
      },
      "apiKey": {
        "type": "string",
        "description": "Optional Cortex API key. Required only when cortexd is configured with API authentication."
      },
      "defaultTarget": {
        "type": "string",
        "enum": [
          "chatgpt",
          "claude",
          "claude-code",
          "codex",
          "cursor",
          "copilot",
          "gemini",
          "grok",
          "windsurf"
        ],
        "default": "chatgpt",
        "description": "Default Cortex portability target used for live routed context."
      },
      "smartRouting": {
        "type": "boolean",
        "default": true,
        "description": "Use Cortex smart routing so each runtime gets the right slice."
      },
      "autoSeedThreads": {
        "type": "boolean",
        "default": true,
        "description": "Automatically materialize Cortex subject and thread scaffolds after turns."
      },
      "projectDirStrategy": {
        "type": "string",
        "enum": [
          "agent-workspace",
          "gateway-cwd",
          "explicit"
        ],
        "default": "agent-workspace",
        "description": "How the plugin resolves the project directory for Cortex calls."
      },
      "projectDir": {
        "type": "string",
        "description": "Explicit project directory when projectDirStrategy is explicit."
      },
      "requestTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "default": 15000,
        "description": "Timeout for Cortex API calls."
      },
      "maxContextChars": {
        "type": "integer",
        "minimum": 256,
        "default": 1500,
        "description": "Maximum routed Cortex context characters injected into each turn."
      },
      "failOpen": {
        "type": "boolean",
        "default": true,
        "description": "If Cortex is unavailable, continue the turn without injected context."
      },
      "namespace": {
        "type": "string",
        "description": "Optional namespace to pin the Cortex API session to."
      },
      "identityFields": {
        "type": "object",
        "additionalProperties": false,
        "description": "Controls which incoming fields the plugin uses when mapping users across channels.",
        "properties": {
          "canonicalSubjectId": {
            "type": "boolean",
            "default": true
          },
          "phoneNumber": {
            "type": "boolean",
            "default": true
          },
          "email": {
            "type": "boolean",
            "default": true
          },
          "username": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  },
  "uiHints": {
    "storeDir": {
      "label": "Cortex Store Directory",
      "placeholder": "~/.openclaw/cortex"
    },
    "apiBaseUrl": {
      "label": "Cortex API Base URL",
      "placeholder": "http://127.0.0.1:8766"
    },
    "apiKey": {
      "label": "Cortex API Key"
    },
    "defaultTarget": {
      "label": "Default Routed Target"
    },
    "smartRouting": {
      "label": "Enable Smart Routing"
    },
    "autoSeedThreads": {
      "label": "Auto Seed Thread Memory"
    },
    "projectDirStrategy": {
      "label": "Project Directory Strategy"
    },
    "projectDir": {
      "label": "Explicit Project Directory"
    },
    "requestTimeoutMs": {
      "label": "Request Timeout (ms)"
    },
    "maxContextChars": {
      "label": "Max Injected Context Chars"
    },
    "failOpen": {
      "label": "Fail Open On Cortex Outage"
    },
    "namespace": {
      "label": "Pinned Cortex Namespace"
    },
    "identityFields": {
      "label": "Identity Mapping Fields"
    }
  }
}
