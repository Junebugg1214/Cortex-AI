{
  "name": "cortexai-openclaw",
  "version": "1.6.0",
  "displayName": "CortexAI OpenClaw",
  "type": "module",
  "description": "Native OpenClaw plugin for Cortex portable context, cross-channel identity resolution, and durable per-user/per-thread memory.",
  "license": "MIT",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/**/*.js",
    "openclaw.plugin.json",
    "config.schema.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Junebugg1214/Cortex-AI.git"
  },
  "homepage": "https://github.com/Junebugg1214/Cortex-AI/tree/main/examples/openclaw-plugin",
  "bugs": {
    "url": "https://github.com/Junebugg1214/Cortex-AI/issues"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "cortex",
    "memory",
    "portable-context",
    "mcp"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.22",
      "minGatewayVersion": "2026.4.22"
    },
    "build": {
      "openclawVersion": "2026.4.22"
    }
  },
  "scripts": {
    "check": "node --check ./src/index.js && node --check ./src/service.js && node --check ./src/hooks.js && node --check ./src/identity.js"
  }
}
