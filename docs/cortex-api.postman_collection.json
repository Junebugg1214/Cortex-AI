{
	"info": {
		"_postman_id": "cortex-caas-api-v1",
		"name": "Cortex CaaS API",
		"description": "Complete API collection for the Cortex Context-as-a-Service API.\n\nSetup:\n1. Start the server: `cortex serve context.json --port 8421`\n2. Create a grant: `cortex grant --create --audience \"Postman\" --policy full`\n3. Set the `token` variable to your grant token\n4. Set `base_url` to your server URL (default: http://localhost:8421)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8421",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your-grant-token-here",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Discovery (No Auth)",
			"item": [
				{
					"name": "Server Info",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": ["{{base_url}}"],
							"path": [""]
						},
						"description": "Returns server name, version, DID, and available endpoints."
					}
				},
				{
					"name": "Health Check",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Returns server health status and timestamp."
					}
				},
				{
					"name": "UPAI Discovery",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/.well-known/upai-configuration",
							"host": ["{{base_url}}"],
							"path": [".well-known", "upai-configuration"]
						},
						"description": "UPAI service discovery document with endpoint URLs and capabilities."
					}
				},
				{
					"name": "Identity (DID Document)",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/identity",
							"host": ["{{base_url}}"],
							"path": ["identity"]
						},
						"description": "Returns the server's W3C DID Document with verification methods."
					}
				},
				{
					"name": "Prometheus Metrics",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/metrics",
							"host": ["{{base_url}}"],
							"path": ["metrics"]
						},
						"description": "Prometheus text exposition format metrics. Requires --enable-metrics flag."
					}
				}
			]
		},
		{
			"name": "Context",
			"item": [
				{
					"name": "Full Context (Signed Graph)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context",
							"host": ["{{base_url}}"],
							"path": ["context"]
						},
						"description": "Returns the full signed knowledge graph, filtered by the token's disclosure policy."
					}
				},
				{
					"name": "Compact Context (Markdown)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context/compact",
							"host": ["{{base_url}}"],
							"path": ["context", "compact"]
						},
						"description": "Returns a markdown summary of the context, suitable for LLM system prompts."
					}
				},
				{
					"name": "List Nodes (Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context/nodes?limit=20",
							"host": ["{{base_url}}"],
							"path": ["context", "nodes"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "cursor", "value": "", "disabled": true }
							]
						},
						"description": "Paginated list of context nodes. Use cursor from response for next page."
					}
				},
				{
					"name": "Get Single Node",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context/nodes/:node_id",
							"host": ["{{base_url}}"],
							"path": ["context", "nodes", ":node_id"],
							"variable": [
								{ "key": "node_id", "value": "replace-with-node-id" }
							]
						},
						"description": "Returns a single node by ID with all properties."
					}
				},
				{
					"name": "List Edges (Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context/edges?limit=20",
							"host": ["{{base_url}}"],
							"path": ["context", "edges"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "cursor", "value": "", "disabled": true }
							]
						},
						"description": "Paginated list of context edges (relationships between nodes)."
					}
				},
				{
					"name": "Graph Statistics",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context/stats",
							"host": ["{{base_url}}"],
							"path": ["context", "stats"]
						},
						"description": "Returns node count, edge count, average degree, and tag distribution."
					}
				},
				{
					"name": "Semantic Search",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/context/search?q=machine+learning&limit=10",
							"host": ["{{base_url}}"],
							"path": ["context", "search"],
							"query": [
								{ "key": "q", "value": "machine+learning" },
								{ "key": "limit", "value": "10" }
							]
						},
						"description": "TF-IDF ranked semantic search across all node fields."
					}
				}
			]
		},
		{
			"name": "Grants",
			"item": [
				{
					"name": "Create Grant",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"audience\": \"my-chatbot\",\n  \"policy\": \"professional\",\n  \"ttl_hours\": 24,\n  \"scopes\": [\"context:read\", \"identity:read\", \"versions:read\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/grants",
							"host": ["{{base_url}}"],
							"path": ["grants"]
						},
						"description": "Create a new grant token. The response includes the signed JWT token. Requires grants:manage scope."
					}
				},
				{
					"name": "List Grants",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/grants",
							"host": ["{{base_url}}"],
							"path": ["grants"]
						},
						"description": "List all active and revoked grants."
					}
				},
				{
					"name": "Revoke Grant",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/grants/:grant_id",
							"host": ["{{base_url}}"],
							"path": ["grants", ":grant_id"],
							"variable": [
								{ "key": "grant_id", "value": "replace-with-grant-id" }
							]
						},
						"description": "Revoke a grant token. The token will immediately stop working."
					}
				}
			]
		},
		{
			"name": "Versions",
			"item": [
				{
					"name": "List Versions (Paginated)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/versions?limit=20",
							"host": ["{{base_url}}"],
							"path": ["versions"],
							"query": [
								{ "key": "limit", "value": "20" },
								{ "key": "cursor", "value": "", "disabled": true }
							]
						},
						"description": "Paginated list of version snapshots (like git log)."
					}
				},
				{
					"name": "Get Single Version",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/versions/:version_id",
							"host": ["{{base_url}}"],
							"path": ["versions", ":version_id"],
							"variable": [
								{ "key": "version_id", "value": "replace-with-version-id" }
							]
						},
						"description": "Returns a single version snapshot with full metadata."
					}
				},
				{
					"name": "Diff Two Versions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/versions/diff?a=version-a-id&b=version-b-id",
							"host": ["{{base_url}}"],
							"path": ["versions", "diff"],
							"query": [
								{ "key": "a", "value": "version-a-id" },
								{ "key": "b", "value": "version-b-id" }
							]
						},
						"description": "Diff two version snapshots. Returns added, removed, and modified nodes/edges."
					}
				}
			]
		},
		{
			"name": "Webhooks",
			"item": [
				{
					"name": "Create Webhook",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://example.com/webhook\",\n  \"events\": [\"context.updated\", \"grant.created\", \"grant.revoked\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/webhooks",
							"host": ["{{base_url}}"],
							"path": ["webhooks"]
						},
						"description": "Register a webhook endpoint. Events are delivered with exponential backoff and circuit breaker protection."
					}
				},
				{
					"name": "List Webhooks",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/webhooks",
							"host": ["{{base_url}}"],
							"path": ["webhooks"]
						},
						"description": "List all registered webhooks."
					}
				},
				{
					"name": "Delete Webhook",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/webhooks/:webhook_id",
							"host": ["{{base_url}}"],
							"path": ["webhooks", ":webhook_id"],
							"variable": [
								{ "key": "webhook_id", "value": "replace-with-webhook-id" }
							]
						},
						"description": "Unregister a webhook. Pending deliveries will be discarded."
					}
				}
			]
		},
		{
			"name": "Policies",
			"item": [
				{
					"name": "List Policies",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/policies",
							"host": ["{{base_url}}"],
							"path": ["policies"]
						},
						"description": "List all disclosure policies (built-in + custom)."
					}
				},
				{
					"name": "Get Policy",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/policies/:name",
							"host": ["{{base_url}}"],
							"path": ["policies", ":name"],
							"variable": [
								{ "key": "name", "value": "professional" }
							]
						},
						"description": "Get details of a single disclosure policy."
					}
				},
				{
					"name": "Create Custom Policy",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"my-custom-policy\",\n  \"include_tags\": [\"technical_expertise\", \"active_priorities\"],\n  \"min_confidence\": 0.7,\n  \"max_nodes\": 50\n}"
						},
						"url": {
							"raw": "{{base_url}}/policies",
							"host": ["{{base_url}}"],
							"path": ["policies"]
						},
						"description": "Create a custom disclosure policy with tag filters, confidence thresholds, and node limits."
					}
				},
				{
					"name": "Delete Custom Policy",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/policies/:name",
							"host": ["{{base_url}}"],
							"path": ["policies", ":name"],
							"variable": [
								{ "key": "name", "value": "my-custom-policy" }
							]
						},
						"description": "Delete a custom policy. Built-in policies (full, professional, technical, minimal) cannot be deleted."
					}
				}
			]
		}
	]
}
