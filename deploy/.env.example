# Cortex CaaS Environment Overrides
# Copy to .env and uncomment as needed.
# These override values from cortex.ini.

# CORTEX_SERVER_HOST=0.0.0.0
# CORTEX_SERVER_PORT=8421

# CORTEX_STORAGE_BACKEND=sqlite
# CORTEX_STORAGE_DB_PATH=/data/cortex.db

# CORTEX_LOGGING_LEVEL=INFO
# CORTEX_LOGGING_FORMAT=json

# CORTEX_SECURITY_CSRF_ENABLED=true
# CORTEX_SECURITY_SSRF_PROTECTION=true

# CORTEX_SSE_ENABLED=false
# CORTEX_SSE_BUFFER_SIZE=1000

# CORTEX_WEBHOOKS_MAX_RETRIES=5
# CORTEX_WEBHOOKS_CIRCUIT_BREAKER_THRESHOLD=5
# CORTEX_WEBHOOKS_DEAD_LETTER_ENABLED=true
