{
  "annotations": { "list": [] },
  "description": "Cortex CaaS — graph metrics, cache performance, SSE, and audit",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Graph Nodes",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "cortex_graph_nodes",
          "legendFormat": "nodes",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Graph Edges",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "cortex_graph_edges",
          "legendFormat": "edges",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Audit Entries",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "cortex_audit_entries_total",
          "legendFormat": "entries",
          "refId": "A"
        }
      ]
    },
    {
      "title": "SSE Subscribers",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "cortex_sse_subscribers_active",
          "legendFormat": "subscribers",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(cortex_cache_hits_total[5m]) / (rate(cortex_cache_hits_total[5m]) + rate(cortex_cache_misses_total[5m]))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "title": "Cache Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "rate(cortex_cache_hits_total[5m])",
          "legendFormat": "hits/s",
          "refId": "A"
        },
        {
          "expr": "rate(cortex_cache_misses_total[5m])",
          "legendFormat": "misses/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "SSE Events by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(cortex_sse_events_total[5m])) by (event_type)",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cortex", "graph"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Cortex — Graph & Cache",
  "uid": "cortex-graph"
}
