{
  "annotations": { "list": [] },
  "description": "Cortex CaaS — webhook deliveries, dead letters, circuit breaker state",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Webhook Delivery Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(cortex_webhook_deliveries_total{status=\"success\"}[5m])) by (webhook_id)",
          "legendFormat": "{{webhook_id}} success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cortex_webhook_deliveries_total{status=\"failure\"}[5m])) by (webhook_id)",
          "legendFormat": "{{webhook_id}} failure",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Dead Letter Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "cortex_webhook_dead_letters",
          "legendFormat": "{{webhook_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "cortex_circuit_breaker_state",
          "legendFormat": "{{webhook_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
            { "type": "value", "options": { "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ]
        }
      }
    },
    {
      "title": "Total Webhook Deliveries",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(cortex_webhook_deliveries_total) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Dead Letters",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(cortex_webhook_dead_letters)",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["cortex", "webhooks"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Cortex — Webhooks",
  "uid": "cortex-webhooks"
}
