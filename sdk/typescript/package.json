{
  "name": "@cortex_ai/sdk",
  "version": "1.4.0",
  "description": "TypeScript SDK for the Cortex CaaS API",
  "author": "Junebugg1214",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Junebugg1214/Cortex-AI.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/Junebugg1214/Cortex-AI#typescript-sdk",
  "bugs": {
    "url": "https://github.com/Junebugg1214/Cortex-AI/issues"
  },
  "keywords": [
    "cortex",
    "ai-identity",
    "caas",
    "context-as-a-service",
    "knowledge-graph",
    "ai-memory",
    "did",
    "verifiable-credentials"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "test": "node --test dist/esm/tests/client.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
