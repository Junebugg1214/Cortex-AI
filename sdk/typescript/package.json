{
  "name": "@cortex-ai/sdk",
  "version": "1.6.0",
  "description": "TypeScript-friendly SDK for the local Cortex API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Junebugg1214/Cortex-AI.git"
  },
  "homepage": "https://github.com/Junebugg1214/Cortex-AI#readme",
  "bugs": {
    "url": "https://github.com/Junebugg1214/Cortex-AI/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check": "node --check ./dist/index.js"
  },
  "keywords": [
    "ai",
    "memory",
    "cortex",
    "sdk",
    "typescript",
    "openapi",
    "self-hosted"
  ],
  "author": "Junebugg1214"
}
