{
  "openapi": "3.1.0",
  "info": {
    "title": "UPAI Context-as-a-Service API",
    "version": "1.0.0",
    "description": "Universal Personal AI Context-as-a-Service (CaaS) API. Provides a portable, disclosure-controlled knowledge graph that any AI agent can query to personalise its responses.",
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8421",
      "description": "Local development server"
    }
  ],
  "security": [],
  "paths": {
    "/": {
      "get": {
        "operationId": "getServerInfo",
        "summary": "Server info",
        "description": "Returns basic server metadata including name, version, and uptime. No authentication required.",
        "tags": ["Server"],
        "security": [],
        "responses": {
          "200": {
            "description": "Server information",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["name", "version", "uptime_seconds"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "example": "upai-caas"
                    },
                    "version": {
                      "type": "string",
                      "example": "1.0.0"
                    },
                    "uptime_seconds": {
                      "type": "number",
                      "example": 3600.5
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/upai-configuration": {
      "get": {
        "operationId": "getDiscovery",
        "summary": "UPAI discovery document",
        "description": "Returns the UPAI discovery document describing available endpoints, supported scopes, and protocol version. No authentication required.",
        "tags": ["Server"],
        "security": [],
        "responses": {
          "200": {
            "description": "Discovery document",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoveryDocument"
                }
              }
            }
          }
        }
      }
    },
    "/identity": {
      "get": {
        "operationId": "getIdentity",
        "summary": "W3C DID Document",
        "description": "Returns the owner's W3C Decentralized Identifier (DID) document. No authentication required.",
        "tags": ["Identity"],
        "security": [],
        "responses": {
          "200": {
            "description": "DID Document",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Identity"
                }
              }
            }
          }
        }
      }
    },
    "/grants": {
      "post": {
        "operationId": "createGrant",
        "summary": "Create grant token",
        "description": "Issues a new scoped grant token that an AI agent can use to access context endpoints. The returned token is shown only once.",
        "tags": ["Grants"],
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["scopes"],
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Human-readable label for this grant.",
                    "example": "ChatGPT personal assistant"
                  },
                  "scopes": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "List of permission scopes for the grant.",
                    "example": ["context:read", "versions:read"]
                  },
                  "expires_at": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Optional expiration timestamp. Null means no expiration.",
                    "example": "2026-12-31T23:59:59Z"
                  },
                  "disclosure_policy": {
                    "$ref": "#/components/schemas/DisclosurePolicy"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Grant created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GrantToken"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listGrants",
        "summary": "List grants",
        "description": "Returns all active grant tokens for the authenticated owner.",
        "tags": ["Grants"],
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of grants",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GrantToken"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/grants/{grant_id}": {
      "delete": {
        "operationId": "revokeGrant",
        "summary": "Revoke grant",
        "description": "Immediately revokes a grant token. Any subsequent requests using the revoked token will be rejected.",
        "tags": ["Grants"],
        "security": [
          { "BearerAuth": [] }
        ],
        "parameters": [
          {
            "name": "grant_id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the grant to revoke.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Grant revoked successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "404": {
            "description": "Grant not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/context": {
      "get": {
        "operationId": "getContext",
        "summary": "Full disclosure-filtered graph",
        "description": "Returns the complete knowledge graph filtered by the disclosure policy attached to the caller's grant token.",
        "tags": ["Context"],
        "security": [
          { "BearerAuth": ["context:read"] }
        ],
        "responses": {
          "200": {
            "description": "Full graph",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Graph"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/context/compact": {
      "get": {
        "operationId": "getContextCompact",
        "summary": "Compact markdown summary",
        "description": "Returns a condensed markdown summary of the disclosure-filtered knowledge graph, suitable for injection into an LLM system prompt.",
        "tags": ["Context"],
        "security": [
          { "BearerAuth": ["context:read"] }
        ],
        "responses": {
          "200": {
            "description": "Markdown summary",
            "content": {
              "text/markdown": {
                "schema": {
                  "type": "string",
                  "example": "# User Context\n\n## Preferences\n- Prefers dark mode\n- Language: English\n"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/context/nodes": {
      "get": {
        "operationId": "listNodes",
        "summary": "Paginated nodes",
        "description": "Returns a paginated list of nodes from the disclosure-filtered knowledge graph.",
        "tags": ["Context"],
        "security": [
          { "BearerAuth": ["context:read"] }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of nodes to return per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Opaque cursor for fetching the next page of results.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of nodes",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Page" },
                    {
                      "type": "object",
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Node"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/context/nodes/{node_id}": {
      "get": {
        "operationId": "getNode",
        "summary": "Single node",
        "description": "Returns a single node by its identifier, subject to the caller's disclosure policy.",
        "tags": ["Context"],
        "security": [
          { "BearerAuth": ["context:read"] }
        ],
        "parameters": [
          {
            "name": "node_id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the node.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Node details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Node"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "404": {
            "description": "Node not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/context/edges": {
      "get": {
        "operationId": "listEdges",
        "summary": "Paginated edges",
        "description": "Returns a paginated list of edges from the disclosure-filtered knowledge graph.",
        "tags": ["Context"],
        "security": [
          { "BearerAuth": ["context:read"] }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of edges to return per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Opaque cursor for fetching the next page of results.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of edges",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Page" },
                    {
                      "type": "object",
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Edge"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/context/stats": {
      "get": {
        "operationId": "getContextStats",
        "summary": "Graph statistics",
        "description": "Returns aggregate statistics about the disclosure-filtered knowledge graph, such as node and edge counts.",
        "tags": ["Context"],
        "security": [
          { "BearerAuth": ["context:read"] }
        ],
        "responses": {
          "200": {
            "description": "Graph statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["node_count", "edge_count", "category_counts"],
                  "properties": {
                    "node_count": {
                      "type": "integer",
                      "description": "Total number of visible nodes.",
                      "example": 142
                    },
                    "edge_count": {
                      "type": "integer",
                      "description": "Total number of visible edges.",
                      "example": 387
                    },
                    "category_counts": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "integer"
                      },
                      "description": "Node counts broken down by category.",
                      "example": {
                        "preference": 35,
                        "fact": 52,
                        "memory": 55
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/versions": {
      "get": {
        "operationId": "listVersions",
        "summary": "Paginated version history",
        "description": "Returns a paginated list of graph versions in reverse chronological order.",
        "tags": ["Versions"],
        "security": [
          { "BearerAuth": ["versions:read"] }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of versions to return per page.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Opaque cursor for fetching the next page of results.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of versions",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Page" },
                    {
                      "type": "object",
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Version"
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/versions/{version_id}": {
      "get": {
        "operationId": "getVersion",
        "summary": "Single version",
        "description": "Returns the full details of a specific graph version, including the snapshot of nodes and edges at that point in time.",
        "tags": ["Versions"],
        "security": [
          { "BearerAuth": ["versions:read"] }
        ],
        "parameters": [
          {
            "name": "version_id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the version.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Version details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Version"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "404": {
            "description": "Version not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/versions/diff": {
      "get": {
        "operationId": "diffVersions",
        "summary": "Diff two versions",
        "description": "Computes the difference between two graph versions, returning added, removed, and modified nodes and edges.",
        "tags": ["Versions"],
        "security": [
          { "BearerAuth": ["versions:read"] }
        ],
        "parameters": [
          {
            "name": "a",
            "in": "query",
            "required": true,
            "description": "Version ID of the base (older) version.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "b",
            "in": "query",
            "required": true,
            "description": "Version ID of the target (newer) version.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Version diff",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["version_a", "version_b", "nodes_added", "nodes_removed", "nodes_modified", "edges_added", "edges_removed"],
                  "properties": {
                    "version_a": {
                      "type": "string",
                      "format": "uuid",
                      "description": "The base version ID."
                    },
                    "version_b": {
                      "type": "string",
                      "format": "uuid",
                      "description": "The target version ID."
                    },
                    "nodes_added": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Node" }
                    },
                    "nodes_removed": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Node" }
                    },
                    "nodes_modified": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": ["before", "after"],
                        "properties": {
                          "before": { "$ref": "#/components/schemas/Node" },
                          "after": { "$ref": "#/components/schemas/Node" }
                        }
                      }
                    },
                    "edges_added": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Edge" }
                    },
                    "edges_removed": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Edge" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request (missing or malformed version IDs)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "403": {
            "description": "Insufficient scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "404": {
            "description": "One or both versions not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks": {
      "post": {
        "operationId": "registerWebhook",
        "summary": "Register webhook",
        "description": "Registers a new webhook URL to receive notifications when the knowledge graph changes.",
        "tags": ["Webhooks"],
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url", "events"],
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "HTTPS URL that will receive POST callbacks.",
                    "example": "https://example.com/hooks/upai"
                  },
                  "events": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": ["context.updated", "context.deleted", "grant.revoked", "version.created"]
                    },
                    "description": "Event types to subscribe to.",
                    "example": ["context.updated", "version.created"]
                  },
                  "secret": {
                    "type": "string",
                    "description": "Optional shared secret used to sign webhook payloads (HMAC-SHA256).",
                    "example": "whsec_abc123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Webhook registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookRegistration"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listWebhooks",
        "summary": "List webhooks",
        "description": "Returns all registered webhooks for the authenticated owner.",
        "tags": ["Webhooks"],
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of webhooks",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WebhookRegistration"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/{webhook_id}": {
      "delete": {
        "operationId": "deleteWebhook",
        "summary": "Delete webhook",
        "description": "Removes a registered webhook. No further events will be delivered to the webhook URL.",
        "tags": ["Webhooks"],
        "security": [
          { "BearerAuth": [] }
        ],
        "parameters": [
          {
            "name": "webhook_id",
            "in": "path",
            "required": true,
            "description": "Unique identifier of the webhook to delete.",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Webhook deleted successfully"
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          },
          "404": {
            "description": "Webhook not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UPAIError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "UPAI grant token",
        "description": "A scoped grant token issued via POST /grants. Include as `Authorization: Bearer <token>`."
      }
    },
    "schemas": {
      "Node": {
        "type": "object",
        "required": ["id", "category", "label", "created_at", "updated_at"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique node identifier.",
            "example": "node_pref_dark_mode"
          },
          "category": {
            "type": "string",
            "description": "Semantic category of the node.",
            "example": "preference"
          },
          "label": {
            "type": "string",
            "description": "Human-readable label.",
            "example": "Prefers dark mode"
          },
          "body": {
            "type": "string",
            "description": "Extended content or description for the node.",
            "example": "User consistently chooses dark themes across all applications."
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Arbitrary key-value metadata attached to the node."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence score from 0.0 to 1.0 indicating how certain this knowledge is.",
            "example": 0.95
          },
          "source": {
            "type": "string",
            "description": "Origin of this node (e.g. extractor name, manual entry).",
            "example": "chatgpt-extractor"
          },
          "disclosure_level": {
            "type": "string",
            "enum": ["public", "trusted", "private"],
            "description": "Visibility tier for disclosure filtering.",
            "example": "trusted"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the node was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the node was last updated."
          }
        }
      },
      "Edge": {
        "type": "object",
        "required": ["id", "source_id", "target_id", "relation", "created_at"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique edge identifier.",
            "example": "edge_001"
          },
          "source_id": {
            "type": "string",
            "description": "ID of the source node.",
            "example": "node_user"
          },
          "target_id": {
            "type": "string",
            "description": "ID of the target node.",
            "example": "node_pref_dark_mode"
          },
          "relation": {
            "type": "string",
            "description": "Semantic label for the relationship.",
            "example": "has_preference"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Strength or importance of the relationship.",
            "example": 0.9
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "description": "Arbitrary key-value metadata attached to the edge."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the edge was created."
          }
        }
      },
      "Graph": {
        "type": "object",
        "required": ["nodes", "edges", "version_id", "generated_at"],
        "properties": {
          "nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Node"
            },
            "description": "All visible nodes in the graph."
          },
          "edges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Edge"
            },
            "description": "All visible edges in the graph."
          },
          "version_id": {
            "type": "string",
            "format": "uuid",
            "description": "The graph version this snapshot corresponds to."
          },
          "generated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this response was generated."
          }
        }
      },
      "Identity": {
        "type": "object",
        "required": ["@context", "id", "authentication"],
        "properties": {
          "@context": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "JSON-LD context URIs.",
            "example": ["https://www.w3.org/ns/did/v1"]
          },
          "id": {
            "type": "string",
            "description": "The DID URI.",
            "example": "did:web:example.com:u:alice"
          },
          "controller": {
            "type": "string",
            "description": "DID of the entity that controls this document.",
            "example": "did:web:example.com:u:alice"
          },
          "authentication": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "did:web:example.com:u:alice#key-1"
                },
                "type": {
                  "type": "string",
                  "example": "Ed25519VerificationKey2020"
                },
                "controller": {
                  "type": "string",
                  "example": "did:web:example.com:u:alice"
                },
                "publicKeyMultibase": {
                  "type": "string",
                  "example": "z6MkhaXgBZDvotDkL5257faiztiGiC2QtKLGpbnnEGta2doK"
                }
              }
            },
            "description": "Authentication verification methods."
          },
          "service": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "example": "did:web:example.com:u:alice#upai-caas"
                },
                "type": {
                  "type": "string",
                  "example": "UPAIContextService"
                },
                "serviceEndpoint": {
                  "type": "string",
                  "format": "uri",
                  "example": "http://localhost:8421"
                }
              }
            },
            "description": "Service endpoints associated with this DID."
          }
        }
      },
      "GrantToken": {
        "type": "object",
        "required": ["id", "scopes", "created_at", "revoked"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the grant."
          },
          "token": {
            "type": "string",
            "description": "The bearer token string. Only included in the creation response; never returned again.",
            "example": "upai_g_abc123def456..."
          },
          "label": {
            "type": "string",
            "description": "Human-readable label.",
            "example": "ChatGPT personal assistant"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Permission scopes granted.",
            "example": ["context:read", "versions:read"]
          },
          "disclosure_policy": {
            "$ref": "#/components/schemas/DisclosurePolicy"
          },
          "expires_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Expiration timestamp, or null if the grant does not expire."
          },
          "revoked": {
            "type": "boolean",
            "description": "Whether this grant has been revoked.",
            "example": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the grant was created."
          }
        }
      },
      "DisclosurePolicy": {
        "type": "object",
        "description": "Controls which parts of the knowledge graph are visible to the grant holder.",
        "properties": {
          "max_level": {
            "type": "string",
            "enum": ["public", "trusted", "private"],
            "description": "Maximum disclosure level the grant can see. Nodes above this level are hidden.",
            "example": "trusted"
          },
          "include_categories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "If set, only nodes in these categories are visible. An empty or absent list means all categories are visible.",
            "example": ["preference", "fact"]
          },
          "exclude_categories": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Nodes in these categories are always hidden, even if they match include_categories.",
            "example": ["medical", "financial"]
          },
          "exclude_node_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Specific node IDs to unconditionally hide.",
            "example": ["node_ssn", "node_bank_account"]
          }
        }
      },
      "Version": {
        "type": "object",
        "required": ["id", "parent_id", "created_at", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this version."
          },
          "parent_id": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "ID of the parent version, or null for the initial version."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this version was created."
          },
          "summary": {
            "type": "string",
            "description": "Human-readable summary of what changed in this version.",
            "example": "Added 3 preference nodes from ChatGPT extraction."
          },
          "node_count": {
            "type": "integer",
            "description": "Total number of nodes in this version snapshot.",
            "example": 142
          },
          "edge_count": {
            "type": "integer",
            "description": "Total number of edges in this version snapshot.",
            "example": 387
          },
          "source": {
            "type": "string",
            "description": "The extractor or process that produced this version.",
            "example": "chatgpt-extractor"
          }
        }
      },
      "Page": {
        "type": "object",
        "required": ["items", "has_more"],
        "description": "Wrapper for paginated list responses.",
        "properties": {
          "items": {
            "type": "array",
            "items": {},
            "description": "The page of results."
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether additional pages are available.",
            "example": true
          },
          "next_cursor": {
            "type": ["string", "null"],
            "description": "Opaque cursor to pass as the `cursor` query parameter to fetch the next page. Null if no more pages.",
            "example": "eyJpZCI6MTAwfQ=="
          },
          "total": {
            "type": "integer",
            "description": "Total number of items across all pages, if known.",
            "example": 142
          }
        }
      },
      "UPAIError": {
        "type": "object",
        "required": ["error", "message"],
        "description": "Standard error response body.",
        "properties": {
          "error": {
            "type": "string",
            "description": "Machine-readable error code.",
            "example": "unauthorized"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description.",
            "example": "Bearer token is missing or invalid."
          },
          "details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Optional structured details about the error."
          }
        }
      },
      "WebhookRegistration": {
        "type": "object",
        "required": ["id", "url", "events", "created_at", "active"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for the webhook registration."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL that receives webhook POST requests.",
            "example": "https://example.com/hooks/upai"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["context.updated", "context.deleted", "grant.revoked", "version.created"]
            },
            "description": "Event types this webhook is subscribed to.",
            "example": ["context.updated", "version.created"]
          },
          "active": {
            "type": "boolean",
            "description": "Whether the webhook is currently active.",
            "example": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the webhook was registered."
          }
        }
      },
      "DiscoveryDocument": {
        "type": "object",
        "required": ["upai_version", "context_endpoint", "grants_endpoint", "identity_endpoint", "scopes_supported"],
        "description": "UPAI discovery document describing the server's capabilities and endpoints.",
        "properties": {
          "upai_version": {
            "type": "string",
            "description": "The UPAI protocol version implemented by this server.",
            "example": "1.0.0"
          },
          "context_endpoint": {
            "type": "string",
            "format": "uri",
            "description": "Base URL for context endpoints.",
            "example": "http://localhost:8421/context"
          },
          "grants_endpoint": {
            "type": "string",
            "format": "uri",
            "description": "URL for grant management.",
            "example": "http://localhost:8421/grants"
          },
          "identity_endpoint": {
            "type": "string",
            "format": "uri",
            "description": "URL for the DID document.",
            "example": "http://localhost:8421/identity"
          },
          "versions_endpoint": {
            "type": "string",
            "format": "uri",
            "description": "URL for version history.",
            "example": "http://localhost:8421/versions"
          },
          "webhooks_endpoint": {
            "type": "string",
            "format": "uri",
            "description": "URL for webhook management.",
            "example": "http://localhost:8421/webhooks"
          },
          "scopes_supported": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of OAuth-style scopes the server supports.",
            "example": ["context:read", "context:write", "versions:read", "webhooks:manage"]
          },
          "disclosure_levels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Ordered list of disclosure levels from least to most restrictive.",
            "example": ["public", "trusted", "private"]
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Server",
      "description": "Server metadata and discovery."
    },
    {
      "name": "Identity",
      "description": "W3C Decentralized Identifier (DID) document."
    },
    {
      "name": "Grants",
      "description": "Scoped access token management."
    },
    {
      "name": "Context",
      "description": "Knowledge graph query endpoints with disclosure filtering."
    },
    {
      "name": "Versions",
      "description": "Graph version history and diffing."
    },
    {
      "name": "Webhooks",
      "description": "Event notification webhook management."
    }
  ]
}